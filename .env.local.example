# Copy this file to .env.local (gitignored) and fill in your values.
# Never commit .env.local.

# --- Telegram notifications (optional) ---
# Omit these to disable notifications — the loop works fine without them.
#
# To get these:
#   1. Open Telegram, chat @BotFather, send /newbot
#   2. Pick a name like "claude-to-code-<yourname>-bot"
#   3. BotFather gives you a token — paste it below
#   4. Send any message to your new bot from your account
#   5. Visit: https://api.telegram.org/bot<TOKEN>/getUpdates
#      Your chat ID is in the response under "chat":{"id": ... }
#
# Use a DEDICATED bot for this — don't reuse a bot from another project.

TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- Loop behavior overrides (optional) ---
# Uncomment to override the preset defaults.

# HEARTBEAT_MINUTES=30       # send a periodic status ping (0 = off)
# SESSION_STOP_PCT=85        # stop when Claude session usage reaches this %
# WEEKLY_STOP_PCT=75         # stop when Claude weekly usage reaches this %
# AUTO_RESUME_ON_429=1       # 1 = pause and resume on rate limit; 0 = exit
