# Operator-wide configuration for the claude-to-code pipeline.
#
# WHERE THIS FILE LIVES:
#   ~/.claude/operator.env
#   (on Windows Git Bash: /c/Users/<you>/.claude/operator.env)
#
# HOW TO CREATE IT:
#   1. The bootstrap-project skill offers to create this file
#      interactively on its first run.
#   2. OR copy this example:
#        cp tools/operator.env.example ~/.claude/operator.env
#      and edit in the values below.
#
# WHAT IT DOES:
#   - Identity fields are snapshotted into specs/operator-context.md
#     each time bootstrap creates a new project.
#   - Telegram fields are read by scripts/ralph/notify.sh directly,
#     so notifications work across every project without per-project setup.
#
# SECURITY:
#   Never commit this file. It's on your machine only. The bootstrap
#   wizard sets chmod 600 (owner-only readable) automatically.

# --- Identity ----------------------------------------------------------------

# Your name, as agents should refer to you.
OPERATOR_NAME=""

# City, Country. Used for timezone-aware assumptions and default privacy regime.
OPERATOR_LOCATION=""

# Legal/regulatory regime that applies to your projects by default. Examples:
#   "GDPR and Dutch law"
#   "CCPA (California)"
#   "LGPD (Brazil)"
#   "none — personal projects only"
OPERATOR_JURISDICTION=""

# Free-form paragraph on how you like agents to work. Keep it under 5 short
# sentences — it goes verbatim into operator-context.md.
OPERATOR_STYLE="Ship over ceremony. Prefer established libraries over custom code. One task at a time. Ask when uncertain."

# --- GitHub ------------------------------------------------------------------

# Your GitHub username. Used when bootstrap creates new repos under your account.
GITHUB_USERNAME=""

# The template repo the bootstrap skill clones from. Format: <user>/<repo>
DEFAULT_TEMPLATE_REPO=""

# --- Telegram notifications (optional) ---------------------------------------
#
# Configure these ONCE here and every project will use them. There is no
# per-project override anymore — simpler that way.
#
# To create the bot and find your chat ID:
#   1. In Telegram, chat with @BotFather → /newbot → pick a name
#      (e.g. "claude-to-code-yourname-bot")
#   2. BotFather returns a token — paste below
#   3. Send any message to your new bot from your own Telegram account
#   4. In a browser, visit:
#        https://api.telegram.org/bot<TOKEN>/getUpdates
#   5. Find "chat":{"id": NNNNNNN} in the response — paste that number below
#
# Leave empty to disable notifications. The loop works fine without them.

TELEGRAM_BOT_TOKEN=""
TELEGRAM_CHAT_ID=""
